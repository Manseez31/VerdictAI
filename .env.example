# Copy this file to .env and fill in your own values.

# Required. Get a key at https://console.groq.com/keys
GROQ_API_KEY=

# Optional. Comma-separated list of origins allowed to call the API
# (CORS). Defaults to localhost only; add your deployed frontend's
# origin here if it's served from somewhere else.
# ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Optional. Max /chat requests per client IP per minute. Default: 20
# RATE_LIMIT_PER_MINUTE=20

# Optional. Python logging level: DEBUG, INFO, WARNING, ERROR. Default: INFO
# LOG_LEVEL=INFO

# ---- Security & Trust Core (see docs/SECURITY_ARCHITECTURE.md) ----

# Redirect HTTP->HTTPS and send HSTS. Enable in production behind TLS.
# Respects X-Forwarded-Proto from a reverse proxy. Default: false
# FORCE_HTTPS=false

# Enforce the hardened CSP (no CDN, no 'unsafe-eval'). This WILL break the
# Tailwind CDN frontend — only enable with a precompiled stylesheet. Default: false
# STRICT_CSP=false

# Remove unverifiable citations from answers entirely instead of flagging them
# with a ⚠️ marker. Default: false (flag, don't hide)
# STRICT_CITATIONS=false

# Path to the tamper-evident (hash-chained) audit log.
# AUDIT_LOG_PATH=data/audit/audit.jsonl

# Optional. Groq model used by POST /translate for Nepali → English answer
# translation (bilingual answers). Default: llama-3.3-70b-versatile
# TRANSLATION_MODEL=llama-3.3-70b-versatile

# Optional. Groq model used by the Legal Case Simulator's five agents.
# Default: llama-3.3-70b-versatile
# CASE_SIM_MODEL=llama-3.3-70b-versatile

# Optional. Groq model used by the Legal Case Intelligence Suite's agents.
# Default: llama-3.3-70b-versatile
# CASE_INTELLIGENCE_MODEL=llama-3.3-70b-versatile

# ---- Retrieval pipeline (see docs/RETRIEVAL.md) ----
# All optional; defaults enable query rewriting + hybrid retrieval.

# Rewrite questions into retrieval-optimized queries. Default: true
# ENABLE_QUERY_REWRITING=true

# Fuse dense + BM25 retrieval via RRF. false = original dense-only. Default: true
# ENABLE_HYBRID_RETRIEVAL=true

# Weights for weighted Reciprocal Rank Fusion. Default: 1.0 each
# DENSE_WEIGHT=1.0
# BM25_WEIGHT=1.0

# RRF damping constant (larger = flatter rank contribution). Default: 60
# RRF_K=60

# Candidates pulled from EACH retriever before fusion. Default: 30
# RETRIEVAL_CANDIDATE_POOL=30

# Emit per-chunk retrieval diagnostics to the log. Default: false
# RETRIEVAL_DEBUG=false

# Cross-encoder reranking (retrieve Top-N -> rerank -> Top-K). Optional, off by
# default. Adds a reranking model + latency. Note: BAAI/bge-reranker-base is
# primarily English/Chinese and underperforms on Nepali (see benchmark);
# consider BAAI/bge-reranker-v2-m3 (multilingual) if enabling. Default: false
# ENABLE_RERANKER=false
# RERANKER_MODEL=BAAI/bge-reranker-base
# RERANK_CANDIDATES=20
# RERANK_TOP_K=5
